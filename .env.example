# ── CHARLY MAILER — переменные окружения ──────────────────
# Скопируй этот файл в .env и заполни нужные значения.
# .env НЕ коммитится в git (см. .gitignore).

# Опционально: дефолтный SMTP для быстрого теста
# DEFAULT_SMTP_HOST=smtp.gmail.com
# DEFAULT_SMTP_PORT=587
# DEFAULT_SMTP_USER=
# DEFAULT_SMTP_PASS=

# Опционально: уровень логирования (DEBUG / INFO / WARNING / ERROR)
# LOG_LEVEL=INFO
